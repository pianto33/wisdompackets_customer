{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron/customer-support-classify",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/customer-support-respond",
      "schedule": "15 * * * *"
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    },
    "api/cron/customer-support-classify.ts": {
      "maxDuration": 60
    },
    "api/cron/customer-support-respond.ts": {
      "maxDuration": 60
    }
  }
}
