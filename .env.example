# Stripe API Keys (get these from Stripe Dashboard)
STRIPE_SECRET_KEY=sk_live_your_actual_stripe_secret_key_here

# Envío saliente vía Gmail SMTP (contraseña de aplicación)
EMAIL_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=pianto33.tp@gmail.com
SMTP_PASSWORD=your_gmail_app_password
MAIL_FROM_ADDRESS=info@wisdompackets.com
SUPPORT_BRAND_NAME=WisdomPackets

# Gemini API Key (for LLM email classification)
GEMINI_API_KEY=your_gemini_api_key_here

# IMAP Configuration (for fetching incoming customer support emails)
# For Gmail, you will need to enable IMAP and generate an "App Password" (contraseña de aplicación)
IMAP_USER=pianto33.tp@gmail.com
IMAP_PASSWORD=your_gmail_app_password
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true

# Operational Parameters
ALERT_EMAIL_RECIPIENT=pianto33.tp@gmail.com

# Seguridad: cancelación automática en Stripe (el LLM solo clasifica)
# STRIPE_AUTO_CANCEL_ENABLED=false  → modo seguro: nunca cancela, solo etiqueta
STRIPE_AUTO_CANCEL_ENABLED=true
AUTO_CANCEL_MIN_CONFIDENCE=0.92

# Vercel (producción + local con misma cola que prod)
CRON_SECRET=generate_a_long_random_secret
BLOB_STORE_ID=store_your_blob_store_id
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token_from_dashboard

# Better Stack — source "wisdom-packets-customer"
BETTERSTACK_SOURCE_TOKEN=your_betterstack_source_token
BETTERSTACK_INGESTING_HOST=s2487060.eu-fsn-3.betterstackdata.com
